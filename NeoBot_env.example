# NeoBot.env.example
# Copia este archivo como NeoBot.env y rellena con tus valores reales
# NUNCA subas NeoBot.env a GitHub

# ── Tokko Broker ─────────────────────────────────
TOKKO_KEY=tu_clave_tokko_aqui

# ── OpenAI ───────────────────────────────────────
OPENAI_KEY=sk-proj-...

# ── Telegram (opcional) ───────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...

# ── Google Calendar / Sheets ──────────────────────
GOOGLE_CALENDAR_ID=miguelro.blescr@gmail.com
ASESOR_EMAIL=miguelro.blescr@gmail.com
SHEET_NAME=CLIENTES NEO

# ── Local: ruta al JSON de credenciales Google ───
# (En Render usas la variable GOOGLE_CREDENTIALS_JSON en lugar de este archivo)
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ── WhatsApp Bridge ───────────────────────────────
WA_BRIDGE_URL=http://localhost:3001

# ── Base de datos ─────────────────────────────────
# Local:  dejar vacío  (usa neolife_crm.db en el directorio actual)
# Render: /tmp/neolife_crm.db  (ya configurado en render.yaml)
# DB_PATH=neolife_crm.db

# ── Puppeteer (WhatsApp bridge) ───────────────────
# Linux/Render:  /usr/bin/chromium
# Mac:           dejar vacío
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
